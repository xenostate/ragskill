# Anon key for public endpoints (recommended — enables RLS)
# SUPABASE_ANON_KEY=eyJ...your-anon-key

# Embedding model (optional, default shown)
EMBED_MODEL=intfloat/multilingual-e5-base

# OpenAI (required for LLM answers)
OPENAI_API_KEY=sk-proj-...your-openai-key

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=123456789:AAH...your-bot-token

# SMTP notifications for assistant forms (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=alerts@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=alerts@example.com
# SMTP_USE_TLS=true

# WhatsApp Business (optional, disabled by default)
# WHATSAPP_ENABLED=true
# WHATSAPP_VERIFY_TOKEN=your-random-verify-token
# WHATSAPP_APP_SECRET=your-meta-app-secret

# Trusted reverse proxy IPs/CIDRs for X-Forwarded-For (optional, default: 127.0.0.1,::1)
# TRUSTED_PROXIES=127.0.0.1,::1

# Tuning (optional, defaults shown)
# RAG_MODEL=gpt-4o-mini
# RAG_TOP_K=5
# CHUNK_SIZE=500
# CHUNK_OVERLAP=50
# REQUEST_DELAY=0.5
# THRESHOLD_HIGH=0.75
# THRESHOLD_MEDIUM=0.5
