      "success_message": "Спасибо! Ваша заявка отправлена. С вами свяжутся в ближайшее время.",
      "fields": [
        {
          "name": "name",
          "label": "Имя",
          "type": "text",
          "required": true,
          "placeholder": "Как к вам обращаться?"
        },
        {
          "name": "phone",
          "label": "Телефон",
          "type": "tel",
          "required": true,
          "placeholder": "+82 10 1234 5678"
        },
        {
          "name": "age",
          "label": "Возраст",
          "type": "number",
          "required": false,
          "placeholder": "Например, 24"
        },
        {
          "name": "current_level",
          "label": "Текущий уровень корейского",
          "type": "select",
          "required": false,
          "options": [
            "Никогда не изучал(а)",
            "Начальный",
            "Базовый",
            "Средний",
            "Выше среднего",
            "Продвинутый"
          ],
          "placeholder": "Выберите ваш уровень"
        },
        {
          "name": "goal",
          "label": "Цель обучения",
          "type": "select",
          "required": false,
          "options": [
            "Для жизни в Корее",
            "Для учебы",
            "Для работы",
            "Подготовка к TOPIK",
            "Для путешествий",
            "Для себя"
          ],
          "placeholder": "Выберите цель"
        },
        {
          "name": "preferred_format",
          "label": "Предпочтительный формат",
          "type": "select",
          "required": false,
          "options": [
            "Онлайн",
            "Оффлайн",
            "Без разницы"
          ],
          "placeholder": "Выберите формат"
        },
        {
          "name": "notes",
          "label": "Комментарий",
          "type": "textarea",
          "required": false,
          "placeholder": "Например: удобное время, срочность, вопросы по программе"
        }
      ],
      "destinations": {
        "email": [],
        "telegram_chat_ids": [],
        "whatsapp_numbers": []
      }
    },
    {
      "id": "level_assessment_form",
      "title": "Запрос на оценку уровня",
