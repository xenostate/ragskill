{
  "display": {
    "title": "Консультант школы корейского языка",
    "input_placeholder": "Напишите ваш вопрос о курсах, расписании или уровне"
  },
  "greeting": {
    "enabled": true,
    "message": "Здравствуйте! Я онлайн-консультант школы корейского языка. Помогу с программами обучения, уровнями, стоимостью, расписанием и записью на консультацию.",
    "show_once": true,
    "delay_ms": 700
  },
  "starters": [
    {
      "id": "courses_info",
      "label": "Какие есть курсы?",
      "action": "send_message",
      "message": "Расскажите, пожалуйста, какие курсы корейского языка у вас есть и кому они подходят."
    },
    {
      "id": "pricing_schedule",
      "label": "Стоимость и расписание",
      "action": "send_message",
      "message": "Расскажите, пожалуйста, о стоимости обучения, формате занятий и расписании."
    },
    {
      "id": "level_request",
      "label": "Оценить мой уровень",
      "action": "open_form",
      "form_id": "level_assessment_form"
    },
    {
      "id": "contact_request",
      "label": "Оставить заявку",
      "action": "open_form",
      "form_id": "contact_form"
    }
  ],
  "forms": [
    {
      "id": "contact_form",
      "title": "Заявка на консультацию",
