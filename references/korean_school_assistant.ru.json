      "submit_label": "Отправить на оценку",
      "success_message": "Спасибо! Запрос на оценку уровня отправлен. С вами свяжутся для следующего шага.",
      "fields": [
        {
          "name": "name",
          "label": "Имя",
          "type": "text",
          "required": true,
          "placeholder": "Ваше имя"
        },
        {
          "name": "phone",
          "label": "Телефон",
          "type": "tel",
          "required": true,
          "placeholder": "+82 10 1234 5678"
        },
        {
          "name": "experience",
          "label": "Есть ли опыт изучения корейского?",
          "type": "select",
          "required": true,
          "options": [
            "Нет, начинаю с нуля",
            "Немного изучал(а)",
            "Изучал(а) несколько месяцев",
            "Изучал(а) больше года"
          ],
          "placeholder": "Выберите вариант"
        },
        {
          "name": "can_read_hangul",
          "label": "Умеете ли вы читать хангыль?",
          "type": "select",
          "required": true,
          "options": [
            "Да, уверенно",
            "Да, но медленно",
            "Совсем нет"
          ],
          "placeholder": "Выберите вариант"
        },
        {
          "name": "goal",
          "label": "Для чего вам корейский язык?",
          "type": "select",
          "required": true,
          "options": [
            "Поступление или учеба",
            "Работа",
            "Переезд",
            "TOPIK",
            "Путешествия",
            "Личный интерес"
          ],
          "placeholder": "Выберите цель"
        },
        {
          "name": "study_schedule",
          "label": "Когда вам удобно заниматься?",
          "type": "select",
          "required": false,
          "options": [
            "Утром",
            "Днем",
            "Вечером",
            "По выходным",
            "Гибкий график"
          ],
          "placeholder": "Выберите время"
        },
        {
          "name": "self_description",
          "label": "Кратко опишите ваш текущий уровень",
          "type": "textarea",
          "required": false,
          "placeholder": "Например: знаю алфавит, могу читать простые слова, понимаю базовые фразы"
        }
      ],
      "destinations": {
        "email": [],
        "telegram_chat_ids": [],
        "whatsapp_numbers": []
      }
    }
